# Copy this to .env and fill in your values
# For local Docker: these defaults already work with docker-compose.yml

POSTGRES_DB=productdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=secret

# Auto-built from above in docker-compose.yml:
# DATABASE_URL=postgresql://appuser:secret@db:5432/productdb

# --- Coolify ---
# In Coolify, set these 3 env vars in the UI.
# DATABASE_URL will be injected automatically if you use Coolify's linked DB.
